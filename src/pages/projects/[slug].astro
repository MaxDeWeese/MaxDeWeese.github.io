---
import { getCollection } from "astro:content";
import Navbar from "../../components/Navbar.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");

  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<html lang="en">
  <head>
    <title>{project.data.title}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>

  <body>
    <Navbar />

    <main class="page">


      <h1>{project.data.title}</h1>
      <!-- 
      <img
        src={project.data.images[0]}
        alt={project.data.title}
        class="cover"
      />-->

<div class="carousel">
  <button class="arrow left" onclick="prevImage()">&larr;</button>

  <div class="track">
    {project.data.images?.map((img) => (
      <img src={img} class="slide" />
    ))}
  </div>

  <button class="arrow right" onclick="nextImage()">&rarr;</button>
</div>

      

      <div class="content" set:html={project.rendered?.html ?? ""} />

    </main>
  </body>
</html>

<style>
.back {
  display: inline-block;
  margin-bottom: 24px;
  text-decoration: none;
  color: #555;
}

.back:hover {
  color: #000;
}

h1 {
  font-size: 48px;
  margin: 0 0 20px 0;
  letter-spacing: -0.02em;
  text-align: center;
}





.cover {
  width: 100%;
  max-width: 800px;
  margin: 20px auto;
  display: block;
  border-radius: 16px;
  object-fit: cover;
}

.desc {
  color: #666;
  margin-top: 0;
  margin-bottom: 24px;
  font-size: 16px;
  line-height: 1.5;
}

.content {
  line-height: 1.6;
}

/* Make markdown look clean */
.content h1,
.content h2,
.content h3 {
  margin-top: 24px;
  margin-bottom: 12px;
}

.content p {
  margin: 12px 0;
}

.content ul {
  padding-left: 20px;
}

.content li {
  margin: 6px 0;
}
.carousel {
  position: relative;
  max-width: 950px;   /* 👈 bigger */
  height: 550px;      /* 👈 bigger */
  margin: 40px auto;

  background: #e5e5e5; /* 👈 gray letterbox */
  border-radius: 16px;
  overflow: hidden;

  display: flex;
  align-items: center;
  justify-content: center;
}

/* container for images */
.track {
  width: 100%;
  height: 100%;
  position: relative;

  display: flex;
  align-items: center;
  justify-content: center;
}

/* KEY FIX: no cropping */
.slide {
  position: absolute;
  max-width: 100%;
  max-height: 100%;

  width: auto;
  height: auto;

  margin: auto;

  object-fit: contain;   /* 👈 THIS fixes cropping */

  opacity: 0;
  transition: opacity 0.3s ease;
}

/* arrows stay centered */
.arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);

  width: 46px;
  height: 46px;

  border-radius: 999px;
  border: none;

  background: rgba(255,255,255,0.9);
  cursor: pointer;

  z-index: 10;

  display: flex;
  align-items: center;
  justify-content: center;

  /* 🔥 FIX GARBLED TEXT */
  font-size: 24px;
  line-height: 1;
  font-family: system-ui, -apple-system, sans-serif;

  color: #111;
  user-select: none;
}

.arrow.left { left: 14px; }
.arrow.right { right: 14px; }
</style>

<script is:inline>
  let current = 0;
  const slides = document.querySelectorAll(".slide");

  function showSlide(index) {
    slides.forEach((s, i) => {
      s.style.opacity = i === index ? "1" : "0";
    });
  }

  function nextImage() {
    current = (current + 1) % slides.length;
    showSlide(current);
  }

  function prevImage() {
    current = (current - 1 + slides.length) % slides.length;
    showSlide(current);
  }

  showSlide(0);
</script>