---
import { getCollection } from "astro:content";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";



export async function getStaticPaths() {
  const projects = await getCollection("projects");
  

  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<html lang="en">
  <head>
    <title>{project.data.title}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="/global.css" />
  </head>

  <body>
    <Navbar />

    <main class="page">


      <h1>{project.data.title}</h1>
      <!-- 
      <img
        src={project.data.images[0]}
        alt={project.data.title}
        class="cover"
      />-->

<div class="carousel">
  <button class="arrow left" onclick="prevImage()">&larr;</button>

  <div class="track">
    {
      project.data.gallery.map((item) => (
        <div class="slide">
          {item.type === "image" ? (
          <div class="image-frame">
            <img src={item.src} alt={item.caption ?? ""} />
              {item.caption && (
                <div class="caption">{item.caption}</div>
              )}
            </div>
          ) : (
        <>
        <iframe
          src={`https://www.youtube.com/embed/${item.id}`}
          title="YouTube video"
          allowfullscreen
        />

      
    </>
  )}
</div>
      ))
    }
  </div>

  <button class="arrow right" onclick="nextImage()">&rarr;</button>
</div>

      

      <div class="content" set:html={project.rendered?.html ?? ""} />

    </main>
    <Footer />
  </body>
</html>

<style>
.back {
  display: inline-block;
  margin-bottom: 24px;
  text-decoration: none;
  color: #555;
}


.back:hover {
  color: #000;
}
.caption {
  position: absolute;
  bottom: 8px;
  left: 6px;

  background: rgba(0, 0, 0, 0.55);
  color: white;

  padding: 4px 10px;
  border-radius: 6px;

  font-size: 13px;
  line-height: 1.3;

  max-width: 80%;
  text-align: left;

  backdrop-filter: blur(6px);

  pointer-events: none;
}

.page h1 {
  font-size: 40px;
  margin-top: 0px;
  margin-bottom: 0px;
  letter-spacing: -0.02em;
  text-align: center;
}





.cover {
  width: 100%;
  max-width: 800px;
  margin: 20px auto;
  display: block;
  border-radius: 16px;
  object-fit: contain;
}

.desc {
  color: #666;
  margin-top: 0;
  margin-bottom: 24px;
  font-size: 16px;
  line-height: 1.4;
}

.content {
  line-height: 1.4;
}


/* Make markdown look clean */




.content ul {
  padding-left: 20px;
}

.content li {
  margin: 12px 0;
}
.carousel {
  position: relative;
  max-width: 950px;
  height: 550px;
  margin: 40px auto;
  margin-top: 12px;

  background: #e5e5e5;
  border-radius: 4px;
  overflow: hidden;

  display: flex;
  align-items: center;
  justify-content: center;
}

/* container for images */
.track {
  width: 100%;
  height: 100%;
  position: relative;

  display: flex;
  align-items: center;
  justify-content: center;
}



/* arrows stay centered */
.arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);

  width: 46px;
  height: 46px;

  border-radius: 999px;
  border: none;

  background: rgba(252,252,252,0.9);
  cursor: pointer;

  z-index: 10;

  display: flex;
  align-items: center;
  justify-content: center;

  /* 🔥 FIX GARBLED TEXT */
  font-size: 24px;
  line-height: 1;
  font-family: system-ui, -apple-system, sans-serif;

  color: #111;
  user-select: none;
}

.arrow.left { left: 14px; }
.arrow.right { right: 14px; }
.slide {
  position: absolute;
  inset: 0;

  display: flex;
  justify-content: center;

  opacity: 0;
  transition: opacity 0.3s ease;
      object-fit: contain;

}

.slide img {
  max-width: 100%;
  max-height: 100%;

  object-fit: contain;
  display: block;
}
.slide iframe {
  width: 100%;
  height: 100%;
  display: block;
}
.image-frame {
  position: relative;

  display: inline-block;
  max-width: 100%;
  max-height: 100%;
    object-fit: fill;


}

</style>

<script is:inline>
  let current = 0;
  let slides = [];

  function showSlide(index) {
    slides.forEach((s, i) => {
      s.style.opacity = i === index ? "1" : "0";
      s.style.pointerEvents = i === index ? "auto" : "none";
    });
  }

  function nextImage() {
    current = (current + 1) % slides.length;
    showSlide(current);
  }

  function prevImage() {
    current = (current - 1 + slides.length) % slides.length;
    showSlide(current);
  }

  document.addEventListener("DOMContentLoaded", () => {
    slides = document.querySelectorAll(".slide");
    showSlide(0);
  });
</script>